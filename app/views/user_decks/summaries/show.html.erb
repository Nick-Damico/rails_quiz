<div>
  <header class="flex flex-col p-4 mb-4 text-2xl bg-gray-900 md:flex-row md:items-center">
    <h2 class="text-left">
      Flashcard Deck Summary:<br>
      <%= @user_deck.deck.title %>
    </h2>
    <dl class="ml-auto font-thin">
      <dt>Completed On</dt>
      <dt class="text-right"><%= strftime(@user_deck.completed_at) %></dt>
    </dl>
  </header>
  <div class="flex flex-col md:flex-row">
    <div class="flex flex-col pb-4 space-y-4 md:w-1/3 md:pb-0 md:pr-4">
      <div class="flex flex-col h-64 p-4 bg-gray-900 rounded-lg">
        <h3 class="mb-4 text-lg uppercase border-b-2 border-gray-800">Score</h3>
        <div class="flex items-center justify-center h-full text-5xl font-thin">
          <%# <%= format_as_two_digits(@user_deck.cards.count) %>  <%#= format_as_two_digits(@user_deck.cards.count) %>
          <%= @user_deck.score %> %
        </div>
      </div>
      <div class="flex flex-col h-64 p-4 bg-gray-900 rounded-lg">
        <h3 class="mb-4 text-lg uppercase border-b-2 border-gray-800">Total Time taken</h3>
        <div class="flex items-center justify-center h-full text-5xl font-thin text-center">
          <p>
            <%= format_time(@user_deck.completed_in_seconds) %>
          </p>
        </div>
      </div>
    </div>
    <div class="flex flex-col flex-grow w-full p-4 bg-gray-900 rounded-lg md:w-2/3 min-h-64">
      <%= turbo_frame_tag :user_deck_cards, class: "flex flex-col flex-1 overflow-x-hidden" do %>
        <%= render "nav", active_tab: @active_tab, user_deck: @user_deck %>
        <div class="flex items-center flex-1 text-5xl font-thin">
          <%= column_chart @chart_data, colors: [ "#10B981", "#EF4444" ], library: { scales: { y: { grid: { color: "#1f2937" } } } } %>
        </div>
      <% end %>
    </div>
  </div>
</div>
